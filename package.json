{
    "name": "@coinmeca/wallet",
    "version": "0.0.1",
    "keywords": [
        "coinmeca",
        "interface",
        "wallet"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/coinmeca/interface"
    },
    "author": "Coinmeca Team <dev@coinmeca.net>",
    "workspaces": [
        "ui-kit",
        "wallet-provider"
    ],
    "scripts": {
        "setup": "git submodule update --init --recursive && cd ui-kit && git fetch origin && git checkout main && git pull origin main && yarn install && cd ../wallet-provider && git fetch origin && git checkout dev && git pull origin dev && yarn install && yarn setup && yarn install:sdk && cd .. && git submodule update --init --recursive",
        "setup:provider": "git submodule update --init --recursive && cd wallet-provider && git fetch origin && git checkout dev && git pull origin dev && yarn install && yarn setup && yarn install:sdk && cd .. && yarn workspace @coinmeca/wallet-provider setup",
        "lint": "next lint",
        "install:ui": "yarn workspace @coinmeca/ui install",
        "install:provider": "yarn workspace @coinmeca/wallet-provider install",
        "install:provider:sdk": "yarn workspace @coinmeca/wallet-provider install:sdk && yarn workspace @coinmeca/wallet-provider install",
        "dev": "next dev",
        "dev:ui": "yarn workspace @coinmeca/ui dev",
        "dev:provider": "yarn workspace @coinmeca/wallet-provider dev",
        "start": "next start",
        "build": "next build",
        "build:ui": "yarn workspace @coinmeca/ui build",
        "build:provider": "yarn workspace @coinmeca/wallet-provider build",
        "build:provider:sdk": "yarn workspace @coinmeca/wallet-provider build:sdk && yarn workspace @coinmeca/wallet-provider build",
        "deploy": "next build && npx vercel --prod",
        "deploy:ui": "yarn workspace @coinmeca/ui deploy",
        "deploy:provider": "yarn workspace @coinmeca/wallet-provider deploy",
        "dist": "npx vercel --prod",
        "clean": "rm -rf ./dist ./build ./.next ./tsconfig.tsbuildinfo ./node_modules/.cache",
        "clean:ui": "yarn workspace @coinmeca/ui clean",
        "clean:provider": "yarn workspace @coinmeca/wallet-provider clean",
        "clean:provider:sdk": "yarn workspace @coinmeca/wallet-provider clean:sdk && yarn workspace @coinmeca/wallet-provider clean",
        "discord": "tsx ./src/app/api/discord/register"
    },
    "dependencies": {
        "@next/env": "14.2.20",
        "@number-flow/react": "^0.4.4",
        "@vercel/analytics": "^1.4.1",
        "crypto-js": "^4.2.0",
        "discord-api-types": "^0.37.111",
        "discord-interactions": "^4.1.0",
        "motion": "^11.14.4",
        "next": "14.2.20",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "sass": "1.83.0",
        "styled-components": "^6.1.13",
        "vercel": "39.2.2",
        "zustand": "^5.0.2"
    },
    "devDependencies": {
        "@svgr/webpack": "^8.1.0",
        "@tanstack/react-query": "^5.62.7",
        "@tanstack/react-query-devtools": "^5.62.7",
        "@types/crypto-js": "^4.2.2",
        "@types/node": "22.10.2",
        "@types/react": "18.3.17",
        "@types/react-dom": "18.3.5",
        "@types/telegram-web-app": "^7.10.1",
        "@types/webworker": "^0.0.7",
        "eslint": "9.17.0",
        "eslint-config-next": "14.2.20",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.2"
    },
    "packageManager": "yarn@4.5.1"
}
